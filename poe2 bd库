    function matches(build) {
      const keyword = els.search.value.trim().toLowerCase();
      const searchable = [build.name, build.className, build.mode, build.budget, build.difficulty, ...build.tags].join(" ").toLowerCase();
      return (!keyword || searchable.includes(keyword)) &&
        (els.classFilter.value === "all" || build.className === els.classFilter.value) &&
        (state.mode === "all" || build.mode === state.mode) &&
        (els.budgetFilter.value === "all" || build.budget === els.budgetFilter.value) &&
        (els.difficultyFilter.value === "all" || build.difficulty === els.difficultyFilter.value);
    }

    function meter(label, value) {
      return `<div class="meter"><span>${label}</span><div class="bar"><span style="width:${value}%"></span></div><span>${value}</span></div>`;
    }

    function renderDetails(build) {
      els.detailTitle.textContent = build.name;
      els.detailList.innerHTML = Object.entries(build.details)
        .map(([title, text]) => `<div class="detail-item"><b>${title}</b><span>${text}</span></div>`)
        .join("");
    }

    function render() {
      const filtered = builds.filter(matches);
      els.count.textContent = `当前显示 ${filtered.length} / ${builds.length} 个BD`;
      els.empty.style.display = filtered.length ? "none" : "block";
      els.grid.innerHTML = filtered.map((build, index) => `
        <article class="build-card">
          <div class="card-art">
            <img src="${build.image}" alt="${build.name}">
            <span class="class-badge">${build.className}</span>
          </div>
          <div class="card-body">
            <h3>${build.name}</h3>
            <div class="meta">
              <span class="tag gold">${build.mode}</span>
              <span class="tag green">${build.budget}造价</span>
              <span class="tag blue">${build.difficulty}</span>
              ${build.tags.map(tag => `<span class="tag">${tag}</span>`).join("")}
            </div>
            <p class="desc">${build.desc}</p>
            <div class="score-row">
              ${meter("清图", build.clear)}
              ${meter("Boss", build.boss)}
              ${meter("生存", build.tank)}
            </div>
            <button class="open-btn" data-index="${index}" type="button">查看BD模板</button>
          </div>
        </article>
      `).join("");

      document.querySelectorAll(".open-btn").forEach(button => {
        button.addEventListener("click", () => renderDetails(filtered[Number(button.dataset.index)]));
      });

      if (filtered[0]) renderDetails(filtered[0]);
    }

    els.modeFilter.addEventListener("click", event => {
      const button = event.target.closest("button");
      if (!button) return;
      state.mode = button.dataset.value;
      els.modeFilter.querySelectorAll("button").forEach(item => item.classList.toggle("active", item === button));
      render();
    });

    [els.search, els.classFilter, els.budgetFilter, els.difficultyFilter].forEach(input => {
      input.addEventListener("input", render);
    });

    render();
  </script>
</body>
</html>

